.container {
  padding: 30rpx;
  background-color: #f8f8f8;
  min-height: 100vh;
}

.title {
  font-size: 52rpx;
  font-weight: bold;
  text-align: center;
  margin: 40rpx 0 60rpx 0;
  color: #07c160;
}

.add-section {
  display: flex;
  margin-bottom: 50rpx;
}

.input {
  flex: 1;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  padding: 20rpx 30rpx;
  font-size: 32rpx;
  background: white;
}

.add-btn {
  margin-left: 20rpx;
  width: 160rpx;
}

.todo-list {
  margin-top: 20rpx;
}

.todo-item {
  display: flex;
  align-items: center;
  background: white;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.completed .todo-text {
  text-decoration: line-through;
  color: #999999;
}

.todo-text {
  flex: 1;
  margin: 0 30rpx;
  font-size: 34rpx;
}

.delete-btn {
  background: #ff4d4f;
  color: white;
  font-size: 26rpx;
}

.footer {
  text-align: center;
  color: #666666;
  margin-top: 80rpx;
  font-size: 28rpx;
}